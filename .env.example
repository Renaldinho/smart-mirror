MQTT_USERNAME=mirror
MQTT_PASSWORD=mirror-secret
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_CLIENT_ID_PREFIX=gesture-service
GESTURE_CONFIG_PATH=/app/config/gestures.yaml
GESTURE_CONTRACT_PATH=/app/shared/gesture-config/contract.json
GESTURE_CAMERA_DEVICE=/dev/video0
PREFER_PICAMERA2=1
CAMERA_INDEX=0
MM_GESTURE_CONFIG_PATH=/opt/magic_mirror/config/gestures.yaml
MM_GESTURE_CONTRACT_PATH=/opt/magic_mirror/shared/gesture-config/contract.json
